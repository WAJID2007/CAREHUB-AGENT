# ============================================
# CAREHUB AI AGENT — ENVIRONMENT VARIABLES
# ============================================
# Copy this file as .env.local for development
# Add these in Vercel Dashboard → Settings → Environment Variables
# ============================================

# --------------------------------------------
# 🧠 AI BRAIN 1: Google Gemini 3.5 Flash
# Get from: https://aistudio.google.com/apikey
# Free tier: 60 requests/minute
# --------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# 🧠 AI BRAIN 2: Groq (Llama 4)
# Get from: https://console.groq.com/keys
# Free tier: 30 requests/minute
# --------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# 🛒 SHOPIFY STORE CONFIGURATION
# Store URL without https://
# --------------------------------------------
SHOPIFY_STORE=carehub1.myshopify.com
SHOPIFY_CLIENT_ID=9fcbf1ac4aff1d303a18a655b06a58fd
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here
SHOPIFY_ACCESS_TOKEN=your_access_token_after_oauth

# --------------------------------------------
# 🌐 APP URL (Vercel Deployment URL)
# After first deploy, update this with your actual URL
# Example: https://carehub-agent.vercel.app
# --------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# --------------------------------------------
# 💾 VERCEL KV (Memory Storage)
# Auto-configured when you add Vercel KV from dashboard
# Vercel Dashboard → Storage → Create KV Database
# --------------------------------------------
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# --------------------------------------------
# 🏭 SUPPLIER: CJ Dropshipping
# Get from: https://developers.cjdropshipping.com/
# Register → Get API Key
# --------------------------------------------
CJ_API_KEY=your_cj_api_key_here
CJ_EMAIL=your_cj_account_email

# --------------------------------------------
# 🔒 SECURITY
# Generate random string: openssl rand -hex 32
# Used for cron job authentication
# --------------------------------------------
CRON_SECRET=your_random_secret_string_here

# --------------------------------------------
# ⚙️ AGENT CONFIGURATION
# Customize agent behavior
# --------------------------------------------
# Profit margin percentage (e.g., 40 = 40% markup)
DEFAULT_PROFIT_MARGIN=40

# Price monitor frequency in hours
PRICE_CHECK_INTERVAL=6

# Default store currency
STORE_CURRENCY=USD

# Agent language preference (responses)
AGENT_LANGUAGE=en

# Max products to check per cron run
MAX_PRODUCTS_PER_CRON=50

# --------------------------------------------
# 📊 OPTIONAL: Future Suppliers
# Uncomment when adding new suppliers
# --------------------------------------------
# ALIEXPRESS_API_KEY=
# ALIEXPRESS_APP_SECRET=
# ZENDROP_API_KEY=
# SPOCKET_API_KEY=
# DSERS_API_KEY=
